{
  "name": "pa-v1",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts --host 127.0.0.1 --port 5173",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite --config web/vite.config.ts build",
    "build:api": "tsup server/index.ts --format cjs --outDir dist/server --sourcemap",
    "start": "node dist/server/index.js",
    "init-auth": "node scripts/init-auth.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-session": "^1.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.20.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.12"
  }
}
