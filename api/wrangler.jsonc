{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "yairb-pa-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-05",
  "routes": [
    { "pattern": "pa.letsilluminate.co/api/*", "zone_name": "letsilluminate.co" }
  ],
  "vars": {
    "PA_API_PORT": "8788",
    "PA_ADMIN_USER": "admin",
    "PA_LLM_PROVIDER": "openai",
    "OPENAI_MODEL": "gpt-4.1-nano",
    "PA_LOG_LLM_TEXT": "1",
    "PA_LOG_CONSOLE_MAX": "20000",
    "SUPABASE_URL": "https://ljblpufziablobrhtpfz.supabase.co"
  },
  "ai": { "binding": "AI" },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  }

  // Secrets (set via `wrangler secret put`):
  // - SUPABASE_SECRET_KEY
  // - OPENAI_API_KEY (optional)
}
